---
import { icac, serviceAreas } from "~/data/icac";
import Icon from "~/components/Icon.astro";

const primaryCity = icac.cities[0];
const otherCities = icac.cities.slice(1).join(" · ");
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center lg:gap-14">
      <div class="overflow-hidden rounded-2xl shadow-md ring-1 ring-black/5">
        <img
          src={serviceAreas.mapImage}
          alt={`${icac.serviceArea} service area map`}
          class="h-full w-full object-cover"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="text-center lg:text-left">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-brand)]">{serviceAreas.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight text-[var(--color-brand-darker)] sm:text-4xl">
          {serviceAreas.headline}
        </h2>
        <p class="mt-5 text-base leading-relaxed text-[var(--color-ink-soft)]">
          {serviceAreas.body}
        </p>

        <dl class="mt-6 space-y-2 text-sm">
          <div class="flex flex-wrap justify-center gap-2 lg:justify-start">
            <dt class="font-bold text-[var(--color-brand-darker)]">Office Hours:</dt>
            <dd class="text-[var(--color-ink-soft)]">{icac.hours}</dd>
          </div>
          <div class="flex flex-wrap justify-center gap-2 lg:justify-start">
            <dt class="font-bold text-[var(--color-brand-darker)]">Response Time:</dt>
            <dd class="text-[var(--color-ink-soft)]">{icac.responseTime}</dd>
          </div>
          <div class="flex flex-wrap justify-center gap-2 lg:justify-start">
            <dt class="font-bold text-[var(--color-brand-darker)]">Primary City:</dt>
            <dd class="text-[var(--color-ink-soft)]">{primaryCity}, {icac.state}</dd>
          </div>
        </dl>

        <div class="mt-5">
          <h3 class="text-sm font-bold text-[var(--color-brand-darker)]">Also Serving:</h3>
          <p class="mt-1 text-sm text-[var(--color-ink-soft)]">{otherCities}</p>
        </div>
      </div>
    </div>

    <div class="mt-14">
      <h3 class="text-center text-2xl font-extrabold tracking-tight text-[var(--color-brand-darker)] sm:text-3xl">
        Find Your ZIP Code
      </h3>
      <p class="mt-2 text-center text-sm text-[var(--color-ink-soft)]">If your ZIP isn't listed, give us a call. We probably still cover you.</p>
      <div class="mt-6 flex justify-center">
        <ul class="grid grid-cols-3 gap-x-6 gap-y-2.5 sm:grid-cols-4 sm:gap-x-10 lg:grid-cols-7">
          {icac.zips.map((zip) => (
            <li class="flex items-center gap-2 text-sm text-[var(--color-ink-soft)]">
              <span class="flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                <Icon name="check" class="h-2.5 w-2.5" />
              </span>
              <span class="font-medium tabular-nums">{zip}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-10 rounded-2xl border border-[var(--color-brand)]/20 bg-[var(--color-brand-lighter)] p-6 text-center sm:p-8">
        <p class="text-base font-semibold text-[var(--color-brand-darker)] sm:text-lg">
          Find your ZIP code? Don't see it? Either way, give us a call.
        </p>
        <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
          We cover most of Pasco and Hillsborough. If your area isn't listed, there's a good chance we still service it.
        </p>
        <div class="mt-5 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={icac.phoneHref}
            class="pop-btn pop-btn--primary inline-flex items-center justify-center gap-2 rounded-full bg-[var(--color-accent)] px-6 py-3 text-base font-bold text-white shadow-md"
          >
            <Icon name="phone" class="h-4 w-4" />
            Call {icac.phone}
          </a>
          <a
            href="#callback"
            class="pop-btn pop-btn--secondary inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-base font-bold text-[var(--color-brand-darker)] ring-1 ring-[var(--color-brand)]/30"
          >
            <Icon name="calendar" class="h-4 w-4" />
            Request Callback
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
