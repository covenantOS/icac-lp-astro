---
import { icac } from "~/data/icac";
import Icon from "~/components/Icon.astro";
---

<header class="relative z-30 bg-[var(--color-brand-darker)] text-white">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3 sm:py-4">
    <a href="#top" class="flex items-center gap-3 flex-shrink-0">
      <img
        src="/images/shared/logo.png"
        alt={icac.name}
        class="h-10 w-auto sm:h-12"
        width="48"
        height="48"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <span class="leading-tight">
        <span class="block text-base font-extrabold tracking-tight sm:text-lg">{icac.name}</span>
        <span class="block text-[11px] font-medium uppercase tracking-[0.18em] text-white/70 sm:text-xs">{icac.tagline}</span>
      </span>
    </a>

    <a
      href={icac.phoneHref}
      class="pop-btn pop-btn--secondary inline-flex flex-shrink-0 items-center gap-2 rounded-full bg-white px-3 py-2 text-sm font-bold text-[var(--color-brand-darker)] sm:px-5 sm:py-2.5 sm:text-base"
    >
      <Icon name="phone" class="h-4 w-4 text-[var(--color-brand)]" />
      <span class="hidden sm:inline">{icac.phone}</span>
      <span class="sm:hidden">Call</span>
    </a>
  </div>
</header>
