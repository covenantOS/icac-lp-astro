---
import { gallery } from "~/data/icac";
---

<section class="bg-[var(--color-brand-lighter)] py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-brand)]">{gallery.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight text-[var(--color-brand-darker)] sm:text-4xl">
        {gallery.headline}
      </h2>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {gallery.items.map((item) => (
        <article class="group overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-black/5 transition hover:shadow-md">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={item.image}
              alt={item.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-5">
            <h3 class="text-base font-bold text-[var(--color-brand-darker)]">{item.title}</h3>
            <p class="mt-1 text-sm text-[var(--color-ink-soft)]">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
