---
import { faqs } from "~/data/icac";
import Icon from "~/components/Icon.astro";
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4">
    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-brand)]">{faqs.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-[var(--color-brand-darker)] sm:text-4xl">
        {faqs.headline}
      </h2>
      <p class="mt-4 text-base text-[var(--color-ink-soft)]">{faqs.intro}</p>
    </div>

    <div class="mt-10 space-y-3">
      {faqs.items.map((item, i) => (
        <details class="group rounded-xl border border-gray-200 bg-[var(--color-brand-lighter)] open:bg-white open:shadow-md transition" open={i === 0}>
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left text-base font-bold text-[var(--color-brand-darker)] [&::-webkit-details-marker]:hidden">
            <span>{item.question}</span>
            <Icon name="chevron-down" class="h-4 w-4 flex-shrink-0 text-[var(--color-brand)] transition group-open:rotate-180" />
          </summary>
          <div class="px-5 pb-5 text-sm leading-relaxed text-[var(--color-ink-soft)]">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
