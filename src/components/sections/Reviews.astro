---
import { icac, reviews } from "~/data/icac";
import Icon from "~/components/Icon.astro";
import GoogleLogo from "~/components/GoogleLogo.astro";

// Google's default-avatar palette — cycled by index for both featured + strip cards.
const avatarColors = ["#1A73E8", "#0F9D58", "#F4B400", "#DB4437", "#9334E6", "#00897B", "#E91E63", "#43A047"];
const STAR_GOLD = "#FBBC04";
---

<section class="bg-[var(--color-brand-light)] py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-brand)]">{reviews.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-[var(--color-brand-darker)] sm:text-4xl">
        {reviews.headline}
      </h2>
      <p class="mt-3 text-sm text-[var(--color-ink-soft)]">{reviews.intro}</p>
    </div>

    <!-- Google rating summary card -->
    <div class="mx-auto mt-8 flex max-w-md items-center gap-4 rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
      <GoogleLogo class="h-9 w-9 flex-shrink-0" />
      <div class="text-left">
        <div class="flex items-center gap-2">
          <span class="text-2xl font-bold text-[#202124]">{icac.googleRating}</span>
          <span class="flex" style={`color: ${STAR_GOLD}`}>
            <Icon name="star" class="h-4 w-4" />
            <Icon name="star" class="h-4 w-4" />
            <Icon name="star" class="h-4 w-4" />
            <Icon name="star" class="h-4 w-4" />
            <Icon name="star" class="h-4 w-4" />
          </span>
        </div>
        <div class="mt-0.5 text-xs text-[#5f6368]">{icac.googleReviewCount} verified Google reviews</div>
      </div>
    </div>

    <!-- Featured review (auto-rotates) -->
    <div id="featured-review" class="featured-stack mx-auto mt-8 max-w-3xl">
      {reviews.items.map((r, i) => (
        <article
          class="featured-item rounded-2xl border border-gray-200 bg-white p-7 text-left shadow-sm transition-opacity duration-700 ease-out sm:p-8"
          data-i={i}
          style={`opacity: ${i === 0 ? 1 : 0}; pointer-events: ${i === 0 ? "auto" : "none"};`}
        >
          <header class="flex items-start gap-4">
            <span
              class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full text-base font-semibold text-white"
              style={`background-color: ${avatarColors[i % avatarColors.length]}`}
            >{r.initials}</span>
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between gap-3">
                <div class="text-sm font-semibold text-[#202124]">{r.name}</div>
                <GoogleLogo class="h-4 w-4 flex-shrink-0" />
              </div>
              <div class="mt-0.5 flex items-center gap-2 text-xs text-[#5f6368]">
                <span class="flex" style={`color: ${STAR_GOLD}`}>
                  <Icon name="star" class="h-3.5 w-3.5" />
                  <Icon name="star" class="h-3.5 w-3.5" />
                  <Icon name="star" class="h-3.5 w-3.5" />
                  <Icon name="star" class="h-3.5 w-3.5" />
                  <Icon name="star" class="h-3.5 w-3.5" />
                </span>
                <span>·</span>
                <span>{r.recency}</span>
              </div>
            </div>
          </header>
          <div class="review-text-wrap mt-4">
            <p class="review-clamp text-[15px] leading-relaxed text-[#3c4043]">{r.text}</p>
            <button
              type="button"
              class="review-toggle mt-2 hidden text-sm font-semibold text-[var(--color-brand)] hover:underline"
              data-expanded="false"
            >Read more</button>
          </div>
        </article>
      ))}
    </div>

    <!-- Pagination dots -->
    <div id="featured-dots" class="mt-4 flex justify-center gap-1.5">
      {reviews.items.map((_, i) => (
        <button
          type="button"
          class={`featured-dot h-1.5 w-1.5 rounded-full transition-all ${i === 0 ? "w-5 bg-[var(--color-brand)]" : "bg-[var(--color-brand)]/30"}`}
          data-i={i}
          aria-label={`Show review ${i + 1}`}
        ></button>
      ))}
    </div>

    <!-- Review strip -->
    <div class="no-scrollbar mt-8 flex gap-4 overflow-x-auto pb-2 text-left snap-x snap-mandatory">
      {reviews.items.map((r, i) => (
        <article class="w-[320px] flex-shrink-0 snap-start rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
          <header class="flex items-start gap-3">
            <span
              class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
              style={`background-color: ${avatarColors[i % avatarColors.length]}`}
            >{r.initials}</span>
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between gap-2">
                <div class="truncate text-sm font-semibold text-[#202124]">{r.name}</div>
                <GoogleLogo class="h-3.5 w-3.5 flex-shrink-0" />
              </div>
              <div class="mt-0.5 flex items-center gap-1.5 text-xs text-[#5f6368]">
                <span class="flex" style={`color: ${STAR_GOLD}`}>
                  <Icon name="star" class="h-3 w-3" />
                  <Icon name="star" class="h-3 w-3" />
                  <Icon name="star" class="h-3 w-3" />
                  <Icon name="star" class="h-3 w-3" />
                  <Icon name="star" class="h-3 w-3" />
                </span>
                <span>·</span>
                <span>{r.recency}</span>
              </div>
            </div>
          </header>
          <div class="review-text-wrap mt-3">
            <p class="review-clamp review-clamp--strip text-sm leading-relaxed text-[#3c4043]">{r.text}</p>
            <button
              type="button"
              class="review-toggle mt-2 hidden text-xs font-semibold text-[var(--color-brand)] hover:underline"
              data-expanded="false"
            >Read more</button>
          </div>
        </article>
      ))}
    </div>

    <!-- Stats footer -->
    <div class="mt-12 flex flex-wrap items-end justify-center gap-x-12 gap-y-6 border-t border-[var(--color-brand)]/15 pt-10">
      <div class="text-center">
        <div class="text-3xl font-extrabold text-[var(--color-brand-darker)]">{icac.socialProof.rating}</div>
        <div class="mt-1 text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">{icac.socialProof.ratingLabel}</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-[var(--color-brand-darker)]">{icac.socialProof.reviews}</div>
        <div class="mt-1 text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">{icac.socialProof.reviewsLabel}</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-[var(--color-brand-darker)]">{icac.socialProof.years}</div>
        <div class="mt-1 text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">{icac.socialProof.yearsLabel}</div>
      </div>
    </div>

    <p class="mt-5 inline-flex w-full items-center justify-center gap-2 text-xs text-[var(--color-ink-soft)]">
      <GoogleLogo class="h-3.5 w-3.5" /> Reviews sourced from Google
    </p>
  </div>
</section>

<style>
  .featured-stack { display: grid; }
  .featured-stack > .featured-item { grid-column: 1; grid-row: 1; }

  @media (min-width: 1024px) {
    .review-clamp {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 5;
      overflow: hidden;
    }
    .review-clamp--strip {
      -webkit-line-clamp: 6;
    }
    .review-clamp.is-expanded {
      display: block;
      -webkit-line-clamp: unset;
      overflow: visible;
    }
  }
</style>

<script>
  // Auto-rotate the featured review every 7 seconds. Pauses while off-screen,
  // hovered, or while any featured card is expanded via "Read more".
  const stack = document.getElementById("featured-review");
  const dotsContainer = document.getElementById("featured-dots");
  if (stack && dotsContainer) {
    const items = Array.from(stack.querySelectorAll<HTMLElement>(".featured-item"));
    const dots = Array.from(dotsContainer.querySelectorAll<HTMLElement>(".featured-dot"));
    let current = 0;
    let timer: number | null = null;
    let visible = true;
    let hovered = false;
    let expanded = false;

    const show = (i: number) => {
      items.forEach((el, idx) => {
        el.style.opacity = idx === i ? "1" : "0";
        el.style.pointerEvents = idx === i ? "auto" : "none";
      });
      dots.forEach((d, idx) => {
        const active = idx === i;
        d.classList.toggle("w-5", active);
        d.classList.toggle("bg-[var(--color-brand)]", active);
        d.classList.toggle("bg-[var(--color-brand)]/30", !active);
      });
      current = i;
    };

    const advance = () => show((current + 1) % items.length);
    const start = () => {
      if (timer || !visible || hovered || expanded) return;
      timer = window.setInterval(advance, 7000);
    };
    const stop = () => {
      if (timer) { window.clearInterval(timer); timer = null; }
    };

    dots.forEach((d) =>
      d.addEventListener("click", () => {
        const i = Number(d.dataset.i);
        show(i);
        stop(); start();
      }),
    );

    stack.addEventListener("mouseenter", () => { hovered = true; stop(); });
    stack.addEventListener("mouseleave", () => { hovered = false; start(); });

    stack.querySelectorAll<HTMLButtonElement>(".review-toggle").forEach((btn) => {
      btn.addEventListener("click", () => {
        const wrap = btn.parentElement!;
        const text = wrap.querySelector<HTMLElement>(".review-clamp")!;
        const open = text.classList.toggle("is-expanded");
        btn.dataset.expanded = String(open);
        btn.textContent = open ? "Show less" : "Read more";
        expanded = Array.from(stack.querySelectorAll<HTMLElement>(".featured-item .review-clamp"))
          .some((el) => el.classList.contains("is-expanded"));
        expanded ? stop() : start();
      });
    });

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(([entry]) => {
        visible = entry.isIntersecting;
        visible ? start() : stop();
      });
      io.observe(stack);
    } else {
      start();
    }
  }

  // Read-more toggles for the strip cards (outside featured stack).
  const initToggle = (wrap: HTMLElement) => {
    const text = wrap.querySelector<HTMLElement>(".review-clamp");
    const btn = wrap.querySelector<HTMLButtonElement>(".review-toggle");
    if (!text || !btn) return;
    const check = () => {
      const isDesktop = window.innerWidth >= 1024;
      const overflows = text.scrollHeight > text.clientHeight + 2;
      btn.classList.toggle("hidden", !isDesktop || (!overflows && btn.dataset.expanded !== "true"));
    };
    check();
    window.addEventListener("resize", check);
    if (!btn.dataset.bound) {
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {
        const open = text.classList.toggle("is-expanded");
        btn.dataset.expanded = String(open);
        btn.textContent = open ? "Show less" : "Read more";
        check();
      });
    }
  };
  document.querySelectorAll<HTMLElement>(".review-text-wrap").forEach(initToggle);
</script>
