---
import { icac, finalCta, hero } from "~/data/icac";
import QuoteForm from "~/components/QuoteForm.astro";
import Icon from "~/components/Icon.astro";
---

<!-- Background painted by parent wrapper in index.astro so this section and
     the Footer share one continuous image. -->
<section class="relative py-16 sm:py-20">
  <div class="mx-auto grid max-w-6xl grid-cols-1 items-start gap-10 px-4 lg:grid-cols-[1.1fr_1fr] lg:gap-12">
    <div class="text-center lg:text-left">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-accent)]">{finalCta.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
        {finalCta.headline}
      </h2>
      <p class="mt-5 mx-auto max-w-xl text-base text-white/85 lg:mx-0">
        {finalCta.body}
      </p>

      <div class="mt-7 flex flex-col items-center gap-3 sm:flex-row sm:justify-start">
        <a
          href={icac.phoneHref}
          class="pop-btn pop-btn--primary inline-flex items-center justify-center gap-2 rounded-full bg-[var(--color-accent)] px-7 py-3.5 text-base font-bold text-white"
        >
          <Icon name="phone" class="h-4 w-4" />
          Call {icac.phone}
        </a>
        <p class="text-xs text-white/60">{icac.responseTime}</p>
      </div>

      <!-- Inline mini trust signals -->
      <ul class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3">
        {hero.trustChips.slice(0, 3).map((chip) => (
          <li class="flex items-center gap-2 text-sm font-semibold text-white/85">
            <span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
              <Icon name="check" class="h-3 w-3" />
            </span>
            <span>{chip}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="lg:pl-2">
      <QuoteForm formId="cta-form" />
    </div>
  </div>
</section>
