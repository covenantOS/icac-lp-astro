---
import { whyUs } from "~/data/icac";
import Icon from "~/components/Icon.astro";
---

<section class="bg-[var(--color-brand-light)] py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="text-center text-3xl font-extrabold tracking-tight text-[var(--color-brand-darker)] sm:text-4xl">
      {whyUs.headline}
    </h2>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {whyUs.features.map((feature) => (
        <article class="rounded-2xl bg-white p-7 text-center shadow-sm ring-1 ring-black/5">
          <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-brand)] text-white shadow-md">
            <Icon name={feature.icon} class="h-6 w-6" />
          </span>
          <h3 class="mt-5 text-xl font-bold text-[var(--color-brand-darker)]">{feature.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-ink-soft)]">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
