---
// Standalone callback form section. Anchored at #callback so the hero CTA
// and mobile sticky CTA can scroll to it.

import QuoteForm from "~/components/QuoteForm.astro";
import { icac } from "~/data/icac";
import Icon from "~/components/Icon.astro";
---

<section id="callback" class="bg-[var(--color-brand-light)] py-16 sm:py-20">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 lg:grid-cols-[1fr_1.1fr] lg:items-start lg:gap-14">
    <div class="text-center lg:text-left">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-brand)]">Request A Callback</p>
      <h2 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight text-[var(--color-brand-darker)] sm:text-4xl">
        We'll Call You Back In Minutes, Not Hours.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-[var(--color-ink-soft)]">
        Tell us a few quick details and we'll have a real person on the line — average callback under 60 seconds during business hours. Need it now? Just call us.
      </p>

      <div class="mt-6 space-y-3 text-sm">
        <div class="flex items-center justify-center gap-3 rounded-xl bg-white p-3 ring-1 ring-black/5 lg:justify-start">
          <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-[var(--color-brand)] text-white">
            <Icon name="phone" class="h-4 w-4" />
          </span>
          <div class="text-left">
            <div class="text-xs uppercase tracking-wide text-[var(--color-ink-soft)]">Call</div>
            <a href={icac.phoneHref} class="text-base font-bold text-[var(--color-brand-darker)] hover:text-[var(--color-brand)]">{icac.phone}</a>
          </div>
        </div>
        <div class="flex items-center justify-center gap-3 rounded-xl bg-white p-3 ring-1 ring-black/5 lg:justify-start">
          <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-[var(--color-brand)] text-white">
            <Icon name="clock" class="h-4 w-4" />
          </span>
          <div class="text-left">
            <div class="text-xs uppercase tracking-wide text-[var(--color-ink-soft)]">Hours</div>
            <div class="text-sm font-semibold text-[var(--color-brand-darker)]">{icac.hours}</div>
          </div>
        </div>
        <div class="flex items-center justify-center gap-3 rounded-xl bg-white p-3 ring-1 ring-black/5 lg:justify-start">
          <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-[var(--color-brand)] text-white">
            <Icon name="home" class="h-4 w-4" />
          </span>
          <div class="text-left">
            <div class="text-xs uppercase tracking-wide text-[var(--color-ink-soft)]">Service Area</div>
            <div class="text-sm font-semibold text-[var(--color-brand-darker)]">{icac.serviceArea}</div>
          </div>
        </div>
      </div>
    </div>

    <div>
      <QuoteForm formId="callback-form" />
    </div>
  </div>
</section>
