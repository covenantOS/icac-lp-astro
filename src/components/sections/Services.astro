---
// Services showcase. The first 3 services get a feature row each (alternating
// image side); the rest get a tighter grid below. Goal: give every service
// real estate so visitors feel ICAC can do the job they came for.

import { icac, services } from "~/data/icac";
import Icon from "~/components/Icon.astro";

const featured = services.slice(0, 4);
const more = services.slice(4);
---

<section id="services" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-brand)]">What We Do</p>
      <h2 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight text-[var(--color-brand-darker)] sm:text-4xl lg:text-5xl">
        Full-Service Heating & Cooling
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-[var(--color-ink-soft)]">
        From a noisy condenser to a full system replacement, and everything in between, we've handled it for Tampa Bay homeowners for 15+ years.
      </p>
    </div>

    <!-- Service category chips for quick scan -->
    <div class="mt-8 flex flex-wrap justify-center gap-2">
      {services.map((s) => (
        <a
          href={`#${s.slug}`}
          class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-brand)]/25 bg-[var(--color-brand-light)] px-3 py-1.5 text-xs font-semibold text-[var(--color-brand-darker)] transition hover:bg-[var(--color-brand)] hover:text-white"
        >
          <Icon name={s.icon} class="h-3.5 w-3.5" />
          {s.shortLabel}
        </a>
      ))}
    </div>

    <!-- Featured services: alternating image/text rows -->
    <div class="mt-14 space-y-16 sm:space-y-20">
      {featured.map((s, i) => (
        <article id={s.slug} class="grid scroll-mt-24 grid-cols-1 items-center gap-8 lg:grid-cols-2 lg:gap-12">
          <div class={`overflow-hidden rounded-2xl shadow-md ring-1 ring-black/5 ${i % 2 === 1 ? "lg:order-2" : ""}`}>
            <img
              src={s.image}
              alt={s.title}
              class="aspect-[4/3] h-full w-full object-cover"
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class={i % 2 === 1 ? "lg:order-1" : ""}>
            <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand-light)] px-3 py-1 text-xs font-bold uppercase tracking-[0.15em] text-[var(--color-brand-darker)]">
              <Icon name={s.icon} class="h-3.5 w-3.5 text-[var(--color-brand)]" />
              {s.shortLabel}
            </div>
            <h3 class="mt-3 text-2xl font-extrabold tracking-tight text-[var(--color-brand-darker)] sm:text-3xl">
              {s.title}
            </h3>
            <p class="mt-2 text-base font-semibold text-[var(--color-brand)]">{s.blurb}</p>
            <p class="mt-4 text-base leading-relaxed text-[var(--color-ink-soft)]">{s.description}</p>
            <ul class="mt-5 grid grid-cols-1 gap-2 sm:grid-cols-2">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-2 text-sm text-[var(--color-ink)]">
                  <span class="mt-0.5 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                    <Icon name="check" class="h-2.5 w-2.5" />
                  </span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            {s.signals && s.signals.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {s.signals.map((sig) => (
                  <span class="inline-flex items-center gap-1 rounded-full bg-[var(--color-accent)]/10 px-2.5 py-1 text-xs font-bold text-[var(--color-accent-dark)]">
                    <Icon name="bolt" class="h-3 w-3" /> {sig}
                  </span>
                ))}
              </div>
            )}
            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={icac.phoneHref}
                class="pop-btn pop-btn--primary inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-5 py-2.5 text-sm font-bold text-white"
              >
                <Icon name="phone" class="h-4 w-4" />
                Call {icac.phone}
              </a>
              <a
                href="#callback"
                class="pop-btn pop-btn--secondary inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-bold text-[var(--color-brand-darker)] ring-1 ring-[var(--color-brand)]/30"
              >
                Request Callback
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- More services grid -->
    {more.length > 0 && (
      <div class="mt-20 border-t border-gray-200 pt-14">
        <h3 class="text-center text-2xl font-extrabold tracking-tight text-[var(--color-brand-darker)] sm:text-3xl">
          More Ways We Help
        </h3>
        <p class="mx-auto mt-3 max-w-xl text-center text-sm text-[var(--color-ink-soft)]">
          Whatever's going on with your system, there's a good chance we've fixed it before.
        </p>
        <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-2">
          {more.map((s) => (
            <article id={s.slug} class="flex scroll-mt-24 gap-5 rounded-2xl border border-gray-200 bg-[var(--color-brand-lighter)] p-6 transition hover:border-[var(--color-brand)]/30 hover:shadow-md">
              <span class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-[var(--color-brand)] text-white shadow-md">
                <Icon name={s.icon} class="h-6 w-6" />
              </span>
              <div class="min-w-0">
                <h4 class="text-lg font-bold text-[var(--color-brand-darker)]">{s.title}</h4>
                <p class="mt-1 text-sm leading-relaxed text-[var(--color-ink-soft)]">{s.description}</p>
                <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-1">
                  {s.bullets.slice(0, 4).map((b) => (
                    <li class="flex items-center gap-1.5 text-xs text-[var(--color-ink-soft)]">
                      <span class="flex h-3 w-3 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                        <Icon name="check" class="h-2 w-2" />
                      </span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
