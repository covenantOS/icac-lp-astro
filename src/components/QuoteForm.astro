---
// Lead-capture form. Submits JSON to the LeadConnector (GHL) webhook and
// redirects to /thank-you on success. UTM/gclid/fbclid + page_url are
// forwarded automatically. See the script block at the bottom.

interface Props {
  formId?: string;
  variant?: "light" | "dark";
}
const { formId = "quote-form", variant = "light" } = Astro.props;
const isDark = variant === "dark";
---

<form
  id={formId}
  class={`space-y-4 rounded-2xl p-6 sm:p-8 ${
    isDark
      ? "bg-white/95 ring-1 ring-white/20 shadow-2xl"
      : "bg-white ring-1 ring-black/5 shadow-2xl"
  }`}
  method="post"
  action="#"
  novalidate
>
  <div class="text-center">
    <h2 class="text-2xl font-bold text-[var(--color-brand-darker)]">Request A Callback</h2>
    <p class="mt-1 text-sm text-[var(--color-ink-soft)]">We'll call you back in minutes, not hours.</p>
  </div>

  <div>
    <label class="mb-1 block text-xs font-semibold text-[var(--color-ink)]" for={`${formId}-name`}>
      Full Name
    </label>
    <input
      id={`${formId}-name`}
      name="full_name"
      required
      autocomplete="name"
      placeholder="Jane Doe"
      class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-base text-[var(--color-ink)] placeholder:text-gray-400 focus:border-[var(--color-brand)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)]/30"
    />
  </div>

  <div>
    <label class="mb-1 block text-xs font-semibold text-[var(--color-ink)]" for={`${formId}-phone`}>
      Phone Number <span class="text-[var(--color-brand)]">*</span>
    </label>
    <input
      id={`${formId}-phone`}
      type="tel"
      name="phone"
      required
      autocomplete="tel"
      placeholder="(813) 000-0000"
      class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-base text-[var(--color-ink)] placeholder:text-gray-400 focus:border-[var(--color-brand)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)]/30"
    />
  </div>

  <div>
    <label class="mb-1 block text-xs font-semibold text-[var(--color-ink)]" for={`${formId}-service`}>
      Service Needed
    </label>
    <select
      id={`${formId}-service`}
      name="service"
      class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-base text-[var(--color-ink)] focus:border-[var(--color-brand)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)]/30"
    >
      <option value="">Select a service…</option>
      <option value="ac-repair">AC Repair</option>
      <option value="ac-installation">New AC / Replacement</option>
      <option value="ac-maintenance">AC Tune-Up / Maintenance</option>
      <option value="heating">Heating / Furnace</option>
      <option value="air-duct-cleaning">Air Duct Cleaning</option>
      <option value="indoor-air-quality">Indoor Air Quality</option>
      <option value="commercial">Commercial</option>
      <option value="other">Other / Not Sure</option>
    </select>
  </div>

  <div>
    <label class="mb-1 block text-xs font-semibold text-[var(--color-ink)]" for={`${formId}-message`}>
      What's going on?
    </label>
    <textarea
      id={`${formId}-message`}
      name="message"
      rows="2"
      placeholder="E.g., AC blowing warm, weird noises, age of system…"
      class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-base text-[var(--color-ink)] placeholder:text-gray-400 focus:border-[var(--color-brand)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)]/30"
    ></textarea>
  </div>

  <button
    type="submit"
    class="pop-btn pop-btn--primary w-full rounded-lg bg-[var(--color-accent)] px-4 py-3.5 text-base font-bold uppercase tracking-wide text-white"
  >
    Request My Callback
  </button>

  <p class="text-center text-xs text-gray-500">
    By submitting, you agree to be contacted about your service request.
  </p>

  <!-- Success no longer rendered inline — the form redirects to /thank-you on success.
       This box only appears on a network failure so users have a recovery path. -->
  <div class="form-error hidden rounded-lg bg-red-50 p-4 text-center text-sm text-red-800 ring-1 ring-red-200">
    Couldn't submit — please call <a href="tel:+18133952324" class="font-bold underline">(813) 395-2324</a> and we'll get you scheduled.
  </div>
</form>

<script define:vars={{ formId }}>
  // POST to LeadConnector (GHL) webhook, then redirect to /thank-you.
  // The webhook accepts JSON; we send the form fields plus any UTM params
  // and the dynamic phone number from the DNI script (when present).
  const WEBHOOK_URL = "https://services.leadconnectorhq.com/hooks/9z6AJkL0xkPy2TPVG0J3/webhook-trigger/b55c79f0-5a52-4a0e-be27-d5080429daa1";
  const THANK_YOU_URL = "/thank-you";

  const form = document.getElementById(formId);
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector("button[type=submit]");
      const errorBox = form.querySelector(".form-error");
      if (errorBox) errorBox.classList.add("hidden");
      if (submitBtn) {
        submitBtn.setAttribute("disabled", "true");
        submitBtn.dataset.original = submitBtn.textContent || "";
        submitBtn.textContent = "Sending…";
      }

      const data = Object.fromEntries(new FormData(form));
      // Pass UTMs through to GHL for attribution.
      const params = new URLSearchParams(window.location.search);
      ["utm_source","utm_medium","utm_campaign","utm_term","utm_content","gclid","fbclid"].forEach((k) => {
        const v = params.get(k);
        if (v) data[k] = v;
      });
      data.page_url = window.location.href;
      data.referrer = document.referrer || "";
      data.form_id = formId;

      try {
        await fetch(WEBHOOK_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        // Notify GTM so call/lead conversions can fire.
        try {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: "lead_form_submit", form_id: formId });
        } catch (_) { /* noop */ }
        window.location.href = THANK_YOU_URL;
      } catch (err) {
        console.error("[icac-lp] form submit failed", err);
        if (submitBtn) {
          submitBtn.removeAttribute("disabled");
          submitBtn.textContent = submitBtn.dataset.original || "Request My Callback";
        }
        if (errorBox) errorBox.classList.remove("hidden");
      }
    });
  }
</script>
